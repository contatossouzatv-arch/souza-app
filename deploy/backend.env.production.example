NODE_ENV=production
PORT=3011
ORIGIN=https://souzatv.app,https://www.souzatv.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/app_souza_cass
REDIS_URL=redis://HOST:6379
JWT_SECRET=troque_por_um_secret_com_mais_de_32_caracteres
JWT_ACCESS_SECRET=troque_por_um_secret_com_mais_de_32_caracteres
JWT_REFRESH_SECRET=troque_por_um_secret_com_mais_de_32_caracteres
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
RESET_TOKEN_TTL_MIN=20
RATE_LIMIT_LOGIN_WINDOW_MIN=10
RATE_LIMIT_LOGIN_MAX=10
LOCKOUT_MAX_FAILS=5
LOCKOUT_MINUTES=10
APP_BASE_URL=https://souzatv.app
MAIL_MODE=console
UPLOADS_BASE_URL=https://api.souzatv.app
GOOGLE_CLIENT_ID=
PROFILE_IMAGE_REQUIRE_REVIEW=true
PROFILE_IMAGE_MAX_SIZE_MB=5
AUTH_ACCESS_COOKIE_NAME=souza_access_token
AUTH_REFRESH_COOKIE_NAME=souza_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_HTTPONLY=true
